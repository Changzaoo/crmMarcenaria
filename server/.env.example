# ============================================================
# Variáveis do SERVIDOR do CRM. Copie para server/.env (não versionar).
# O servidor carrega server/.env e, como fallback, o .env da raiz do CRM.
# ============================================================

# ---- Assistente de IA (chat do site) — NVIDIA NIM (OpenAI-compatible) ----
# Obtenha a chave em build.nvidia.com. Sem ela o chat fica indisponível (503),
# mas o restante do CRM funciona normalmente.
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# (Opcional) endpoint OpenAI-compatible — padrão: https://integrate.api.nvidia.com/v1
# NVIDIA_BASE_URL=
TEMPERATURE=0.4

# Ajustes opcionais do chat:
# CHAT_MAX_MESSAGES=12
# CHAT_MAX_TOOL_ROUNDS=3
# CHAT_RATE_MAX=30
# CHAT_TIMEOUT_MS=60000

# ---- Outras (opcionais em dev local) ----
# PORT=3001
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# SUPABASE_SERVICE_KEY=   # deixe vazio para rodar 100% local (SQLite + disco)
