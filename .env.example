ALLOWED_ORIGINS=https://linea-marcenaria.vercel.app,https://crm-marcenaria.vercel.app,https://marcenaria.nexusholding.xyz,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174
FIREBASE_PROJECT_ID=device-streaming-20a455a9
FIREBASE_DATABASE_URL=https://device-streaming-20a455a9-default-rtdb.firebaseio.com
FIREBASE_DATABASE_PATH=linear-crm/database
FIREBASE_DATA_ENABLED=1
SUPABASE_URL=https://fepyzmawcsetlyinztjc.supabase.co
SUPABASE_SERVICE_KEY=coloque-a-chave-secreta-no-ambiente-do-servidor
SUPABASE_BUCKET=linear-images

# ---- Assistente de IA (chat do site -> conversas/leads no CRM) ----
# Provedor NVIDIA NIM (catalogo NVIDIA, endpoint OpenAI-compatible) — mesmo do projeto vnmax.
# Sem NVIDIA_API_KEY o chat responde 503 (indisponivel); o resto do CRM funciona normal.
# Pode ficar aqui (.env na raiz) OU em server/.env — o servidor carrega os dois.
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# Criatividade do modelo (0.3 a 0.5 recomendado para atendimento).
TEMPERATURE=0.4
# Ajustes opcionais do chat:
# CHAT_MAX_MESSAGES=12      # historico maximo enviado ao modelo
# CHAT_MAX_TOOL_ROUNDS=3    # rodadas de tool-calling (captura de lead)
# CHAT_RATE_MAX=30          # mensagens por minuto por IP
# CHAT_TIMEOUT_MS=60000     # timeout por resposta

# ---- Tempo real (simbiose CRM <-> landing) ----
# URL do relay WebSocket compartilhado com a landing. Sem isto, o CRM apenas
# persiste (sem notificar o cliente ao vivo). Ex.: wss://linear-realtime-relay.onrender.com
RELAY_URL=

# ---- Billing / Kiwify ----
KIWIFY_CHECKOUT_URL=
# Segurança do webhook: prefira o SECRET (valida assinatura HMAC do corpo).
# TOKEN é alternativa/legado. Sem nenhum dos dois, o webhook fica aberto (apenas dev).
KIWIFY_WEBHOOK_SECRET=
KIWIFY_WEBHOOK_TOKEN=
TRIAL_DAYS=14
